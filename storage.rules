service firebase.storage {
  match /b/{bucket}/o {
    // Avatars - writers upload their own
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Covers - writers upload their own
    match /covers/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Post images - writers upload for their posts
    match /posts/{authorId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == authorId;
    }
  }
}