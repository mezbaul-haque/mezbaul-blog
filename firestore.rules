rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isWriter(userId) {
      return isAuthenticated()
        && request.auth.uid == userId
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['writer', 'admin'];
    }

    function hasAccountRole() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['reader', 'writer', 'admin'];
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isActiveWriter() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['writer', 'admin']
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }

    function writerDraftUpdateIsSafe() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title',
          'slug',
          'category',
          'summary',
          'heroImage',
          'thumbImage',
          'intro',
          'sections',
          'related',
          'status',
          'submittedAt',
          'updatedAt'
        ])
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.status in ['draft', 'submitted']
        && resource.data.status != 'approved';
    }

    // Users collection - public read, writers manage own profile, admins manage all
    match /users/{userId} {
      allow read: if (resource.data.approvalStatus == 'approved' && resource.data.isProfileVisible == true)
        || isOwner(userId)
        || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role in ['reader', 'writer']
        && (
          (request.resource.data.role == 'writer' && request.resource.data.approvalStatus == 'pending')
          || (request.resource.data.role == 'reader' && request.resource.data.approvalStatus == 'approved')
        )
        && request.resource.data.isProfileVisible == false;
      allow update: if isAdmin()
        || (
          hasAccountRole()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.isActive == resource.data.isActive
          && request.resource.data.approvalStatus == resource.data.approvalStatus
          && request.resource.data.isProfileVisible == resource.data.isProfileVisible
          && request.resource.data.approvedAt == resource.data.approvedAt
          && request.resource.data.approvedBy == resource.data.approvedBy
        );
      allow delete: if isAdmin();
    }

    // Posts collection - public read, admins write
    match /posts/{slug} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Drafts collection - private per writer, admins can review
    match /drafts/{draftId} {
      allow read: if isActiveWriter()
        && (resource.data.authorId == request.auth.uid || isAdmin());
      allow create: if isActiveWriter()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status == 'draft';
      allow update: if (isActiveWriter()
          && resource.data.authorId == request.auth.uid
          && writerDraftUpdateIsSafe())
        || isAdmin();
      allow delete: if (isActiveWriter() && resource.data.authorId == request.auth.uid)
        || isAdmin();
    }

    // Likes collection - authenticated users can like posts
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly(['userId', 'postId', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postId is string
        && likeId == request.auth.uid + '_' + request.resource.data.postId;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // Follows collection - authenticated users can follow writers
    match /follows/{followId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly(['followerId', 'writerId', 'createdAt'])
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.writerId is string
        && followId == request.auth.uid + '_' + request.resource.data.writerId;
      allow delete: if isAuthenticated()
        && resource.data.followerId == request.auth.uid;
    }

    // Comments collection - authenticated users can comment on posts
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasOnly(['postId', 'userId', 'content', 'createdAt', 'updatedAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.content is string
        && request.resource.data.createdAt is timestamp;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'updatedAt'])
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.postId == resource.data.postId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid)
        || isAdmin();
    }
  }
}
